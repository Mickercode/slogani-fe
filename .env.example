# ─────────────────────────────────────────────────────────────────────────────
# Slogani Consults Platform — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Supabase gives you connection strings under: Project → Settings → Database.
#
# DATABASE_URL  = the POOLED connection (Transaction mode, port 6543). Used by the
#                 app at runtime. Append ?pgbouncer=true.
# DIRECT_URL    = the DIRECT connection (Session mode, port 5432). Used ONLY by
#                 `prisma migrate` / introspection (DDL needs a direct connection).
#
# Replace [PASSWORD] and [PROJECT-REF] with your project's values.
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ── Auth.js (NextAuth v5) ───────────────────────────────────────────────────
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""
# Base URL of the app (used for callbacks / email links).
AUTH_URL="http://localhost:3000"

# ── Resend (transactional email — Phase 1 verification/reset) ───────────────
RESEND_API_KEY=""
EMAIL_FROM="Slogani Consults <noreply@example.com>"

# ── Cloudinary (document/image storage — Phase 1) ───────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── App-layer encryption key for PII (NIN, biometrics) ──────────────────────
# 32-byte key, base64. Generate with: openssl rand -base64 32
PII_ENCRYPTION_KEY=""
